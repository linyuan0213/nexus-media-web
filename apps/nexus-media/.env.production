VITE_BASE=/

# 接口地址（生产环境由 Nginx / FastAPI 统一代理）
# 注意：API 函数内已包含 /api 前缀，此处 baseURL 用 /
VITE_GLOB_API_URL=/

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=brotli

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式（history 模式需配合 Nginx try_files）
VITE_ROUTER_HISTORY=history

# 是否注入全局 loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成 dist.zip
VITE_ARCHIVER=false
